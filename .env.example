BOT_TOKEN=your_bot_token_here
# Числовой Telegram ID старосты (узнать: @userinfobot). Можно несколько через запятую.
ELSTAROST_TELEGRAM_IDS=123456789
# Дополнительно: username без @ (если ID ещё не прописан)
ELSTAROST_USERNAMES=v9rsh1nk4
# Учебная группа в боте создаётся старостой (/create_group). Ниже — дефолт для РУЗ и обратная совместимость.
GROUP_NAME=ПИ19-5
# Дефолтный URL РУЗ. При создании группы староста выбирает свой вуз
# (https://ruz.fa.ru — Финуниверситет, https://ruz.guz.ru — ГУЗ, и др.)
RUZ_BASE_URL=https://ruz.fa.ru
# Дефолтный поиск в РУЗ, если у группы не задан свой (ставится при создании группы)
RUZ_GROUP_SEARCH=ПИ19-5
# Фоновая досинхронизация расписания с РУЗ (смены аудиторий, отмены, замены). По умолчанию каждые 2 часа.
# Окно (от сегодня): _PAST_DAYS назад и _FUTURE_DAYS вперёд.
RUZ_SCHEDULE_REFRESH_HOURS=2
RUZ_SCHEDULE_REFRESH_PAST_DAYS=14
RUZ_SCHEDULE_REFRESH_FUTURE_DAYS=45
# --- Мини-приложение (Telegram Web App) ---
# Публичный URL БЕЗ слэша в конце. Для Telegram обязателен HTTPS (не http://127.0.0.1).
# Прод: поддомен на Timeweb/VPS с проксированием на WEBAPP_PORT — см. deploy/timeweb/TIMEWEB_WEBAPP_DOMAIN.txt
# Локально: ngrok/cloudflared → временный https://... в эту строку. См. WEBAPP_RUN.txt
WEBAPP_PUBLIC_URL=https://поддомен.ВАШ_ЛОГИН.tw1.ru
# На чём слушает бот (внутри машины). Туннель (cloudflared/ngrok) пробрасывает на WEBAPP_PORT.
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=9090
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
UPLOAD_DIR=./data/uploads
# Максимум размера одного файла при загрузке ДЗ (бот и мини-приложение), МБ
HOMEWORK_UPLOAD_MAX_MB=20
TZ=Europe/Moscow

# IMAP (логин = e-mail группы в боте). Оставьте пустым для авто-подбора по домену (yandex.ru → imap.yandex.ru).
# IMAP_HOST=
# IMAP_HOST=imap.mail.ru
IMAP_PORT=993
IMAP_USE_SSL=1
# Лимиты вложений из писем (Telegram ~50 МБ на файл)
EMAIL_ATTACHMENT_MAX_BYTES=50331648
EMAIL_ATTACHMENT_MAX_COUNT=15

# VPS (Timeweb и др.): пошагово — deploy/timeweb/TIMEWEB.txt
